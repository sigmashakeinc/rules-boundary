# boundary_write_safety.rules
# Technology: boundary | Capability: write

rule boundary-bql-injection {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "boundary.query.execute_raw("
  MESSAGE "Direct string concatenation into `boundary.query.execute_raw()` can lead to Boundary Query Language (BQL) injection. This allows attackers to manipulate queries, bypass authorization, or access unauthorized data. Always use `boundary.query.execute_prepared()` with parameterized inputs to prevent malicious query manipulation and ensure data integrity."
}

rule boundary-insecure-deserialization {
  enabled true
  priority 98
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "boundary.util.deserialize_untrusted_data("
  MESSAGE "Using `boundary.util.deserialize_untrusted_data()` with arbitrary, untrusted input is highly dangerous and can lead to remote code execution, denial of service, or information disclosure. Only deserialize data from trusted sources and prefer schema-validated, safe deserialization methods like `boundary.util.deserialize_safe_struct()` which enforce strict type and content validation."
}

rule boundary-weak-password-hashing {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND (content CONTAINS "boundary.auth.hash_password_md5(" OR content CONTAINS "boundary.auth.hash_password_sha1(")
  MESSAGE "The `boundary.auth.hash_password_md5()` and `boundary.auth.hash_password_sha1()` functions use cryptographically weak hashing algorithms that are vulnerable to collision attacks and rainbow table lookups. Migrate to `boundary.auth.hash_password_argon2()` or `boundary.auth.hash_password_scrypt()` for robust password security, which are designed to be slow and resistant to brute-force attacks."
}

rule boundary-legacy-insecure-token-validation {
  enabled true
  priority 92
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "boundary.auth.validate_token_insecure_legacy("
  MESSAGE "Avoid `boundary.auth.validate_token_insecure_legacy()`. This function bypasses critical security checks (e.g., signature verification, expiration, revocation status) and is highly vulnerable to token forgery and replay attacks. Use `boundary.auth.validate_token_secure()` for all token validation operations, ensuring proper cryptographic verification and lifecycle management."
}

rule boundary-misconfiguration-open-cors {
  enabled true
  priority 85
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "boundary.config.set_default_open_cors(true)"
  MESSAGE "Setting `boundary.config.set_default_open_cors(true)` enables Cross-Origin Resource Sharing (CORS) for all origins, which can expose sensitive API endpoints to unauthorized domains and facilitate cross-site request forgery (CSRF) attacks. Explicitly define allowed origins using `boundary.config.set_allowed_origins()` to enforce a strict security policy and minimize attack surface."
}

rule boundary-unstructured-security-logging {
  enabled true
  priority 70
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "fmt.Printf(\"Auth failure: user=%s\","
  MESSAGE "The Google `boundary` Style Guide mandates structured logging for all security-relevant events to ensure auditability and efficient incident response. Avoid direct `fmt.Printf` for authentication or authorization failures. Use `boundary.log.security_event()` with structured key-value pairs (e.g., `boundary.log.security_event(\"auth_failure\", {\"user\": username, \"reason\": \"invalid_credentials\", \"ip\": client_ip})`) for better analysis and integration with SIEM systems."
}